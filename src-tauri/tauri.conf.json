{
  "$schema": "https://raw.githubusercontent.com/nicodd/tauri-schema/main/resources/schema.json",
  "productName": "AI Desktop",
  "identifier": "ai.desktop",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.svg",
      "icons/128x128.svg",
      "icons/icon.svg",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "ai-sidebar",
        "title": "AI Desktop",
        "width": 380,
        "height": 600,
        "resizable": true,
        "minWidth": 300,
        "minHeight": 400,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; font-src 'self' data:;"
    }
  }
}
